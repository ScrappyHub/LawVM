{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lawvm.receipt.v1",
  "type": "object",
  "required": [
    "schema",
    "event",
    "stamp_utc",
    "repo_root"
  ],
  "properties": {
    "schema": {
      "const": "lawvm.receipt.v1"
    },
    "event": {
      "type": "string",
      "enum": [
        "lawvm.selftest.v1"
      ]
    },
    "stamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
